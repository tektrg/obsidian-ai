{
	"name": "ai-chat-sidebar",
	"version": "1.0.3",
	"description": "Chat sidebar with Claude Max OAuth, Anthropic API keys, and ChatGPT Plus/Codex support.",
	"main": "main.js",
	"type": "module",
	"files": [
		"main.js",
		"manifest.json",
		"styles.css",
		"versions.json"
	],
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"claude",
		"anthropic",
		"ai"
	],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/diff-match-patch": "^1.0.36",
		"@types/node": "^16.11.6",
		"esbuild": "^0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.87",
		"@mariozechner/pi-agent-core": "0.73.1",
		"@mariozechner/pi-coding-agent": "0.73.1",
		"diff-match-patch": "^1.0.5",
		"incremark-renderer": "^1.1.0",
		"obsidian": "latest"
	}
}
